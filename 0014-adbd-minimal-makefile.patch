[PATCH] adbd: minimal Makefile for USB shell-only build

Modify the adbd Makefile to exclude unnecessary source files
when ADBD_MINIMAL is defined.

Excluded files and their typical sizes (stripped ARM):
- backup_service.c      (~4KB) - adb backup/restore
- framebuffer_service.c (~3KB) - adb shell screenrecord  
- jdwp_service.c        (~8KB) - Java debugging
- log_service.c         (~2KB) - adb logcat
- remount_service.c     (~2KB) - adb remount
- file_sync_service.c   (~4KB) - adb push/pull
- transport_local.c     (~5KB) - TCP transport (USB-only mode)

Total estimated code size reduction: ~28KB

Also reduces:
- Static data/bss sections
- Runtime memory allocations
- Attack surface

Usage: Build with 'make ADBD_MINIMAL=1'

Signed-off-by: Buildroot User <user@example.com>
---
 debian/makefiles/adbd.mk | 21 +++++++++++++++------
 1 file changed, 15 insertions(+), 6 deletions(-)

--- a/debian/makefiles/adbd.mk	2026-03-29 11:16:59.607254883 +0800
+++ b/debian/makefiles/adbd.mk	2026-03-29 11:18:14.794649225 +0800
@@ -13,23 +13,29 @@
 SRCS+= android_reboot.c
 
 #VPATH+= ../adb
-SRCS+=  adb.c
-SRCS+=	backup_service.c
+SRCS+=	adb.c
 SRCS+=	fdevent.c
 SRCS+=	transport.c
-SRCS+=	transport_local.c
 SRCS+=	transport_usb.c
 SRCS+=	adb_auth_client.c
 SRCS+=	sockets.c
 SRCS+=	services.c
+SRCS+=	usb_linux_client.c
+SRCS+=	utils.c
+SRCS+=	base64.c
+
+# Minimal build excludes these services when ADBD_MINIMAL is set
+ifeq ($(ADBD_MINIMAL),1)
+CPPFLAGS+= -DADBD_MINIMAL
+else
+SRCS+=	backup_service.c
 SRCS+=	file_sync_service.c
 SRCS+=	jdwp_service.c
 SRCS+=	framebuffer_service.c
 SRCS+=	remount_service.c
-SRCS+=	usb_linux_client.c
 SRCS+=	log_service.c
-SRCS+=	utils.c
-SRCS+=	base64.c
+SRCS+=	transport_local.c
+endif
 
 VPATH+= ../libzipfile
 SRCS+= centraldir.c
