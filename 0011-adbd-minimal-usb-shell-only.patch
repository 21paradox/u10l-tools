[PATCH] adbd: minimal USB shell only

Remove unused services to create a minimal adbd that only supports
USB shell functionality. This reduces binary size and attack surface.

When ADBD_MINIMAL is defined at compile time, following services 
are disabled:
- framebuffer (adb shell screenrecord)
- recover (recovery mode update)
- jdwp (debugging)
- log (adb logcat)
- sync (adb push/pull)
- remount (adb remount)
- reboot (adb reboot)
- root (adb root)
- backup/restore (adb backup/restore)
- tcpip (adb tcpip)
- usb (adb usb)

Only shell service is kept for basic USB debugging.

Usage: Add -DADBD_MINIMAL to CPPFLAGS when building adbd

Signed-off-by: Buildroot User <user@example.com>
---
 core/adb/services.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/core/adb/services.c b/core/adb/services.c
index d85f8f0..abcdef0 100644
--- a/core/adb/services.c
+++ b/core/adb/services.c
@@ -442,6 +442,7 @@ int service_to_fd(const char *name)
 #else /* !ADB_HOST */
     } else if(!strncmp("dev:", name, 4)) {
         ret = unix_open(name + 4, O_RDWR);
+#ifndef ADBD_MINIMAL
     } else if(!strncmp(name, "framebuffer:", 12)) {
         ret = create_service_thread(framebuffer_service, 0);
     } else if(recovery_mode && !strncmp(name, "recover:", 8)) {
@@ -450,12 +451,14 @@ int service_to_fd(const char *name)
         ret = create_jdwp_connection_fd(atoi(name+5));
     } else if (!strncmp(name, "log:", 4)) {
         ret = create_service_thread(log_service, get_log_file_path(name + 4));
+#endif
     } else if(!HOST && !strncmp(name, "shell:", 6)) {
         if(name[6]) {
             ret = create_subproc_thread(name + 6);
         } else {
             ret = create_subproc_thread(0);
         }
+#ifndef ADBD_MINIMAL
     } else if(!strncmp(name, "sync:", 5)) {
         ret = create_service_thread(file_sync_service, NULL);
     } else if(!strncmp(name, "remount:", 8)) {
@@ -480,6 +483,7 @@ int service_to_fd(const char *name)
         ret = create_service_thread(restart_tcp_service, (void *)port);
     } else if(!strncmp(name, "usb:", 4)) {
         ret = create_service_thread(restart_usb_service, NULL);
+#endif /* ADBD_MINIMAL */
 #endif
 #if 0
     } else if(!strncmp(name, "echo:", 5)){
